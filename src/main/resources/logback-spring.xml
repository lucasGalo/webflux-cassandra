<configuration>

    <!-- Pega variáveis do Spring ou do ambiente -->
    <springProperty name="name" source="spring.application.name"/>
    <springProperty name="lokiUrl" source="vars.URL_LOKI"/>
    <springProperty name="podName" source="POD_NAME"/>
    <springProperty name="podNamespace" source="POD_NAMESPACE"/>

    <!-- Loki Appender -->
    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>${lokiUrl}</url>
        </http>
        <format>
            <label>
                <pattern>app=${name},pod=${podName},namespace=${podNamespace},host=${HOSTNAME},level=%level</pattern>
                <readMarkers>true</readMarkers>
            </label>
            <message>
                <pattern>
                    {
                    "timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}",
                    "level":"%level",
                    "logger":"%logger{36}",
                    "thread":"%thread",
                    "message":"%message",
                    "requestId":"%X{X-Request-ID}",
                    "app":"${name}",
                    "pod":"${podName}",
                    "namespace":"${podNamespace}",
                    "host":"${HOSTNAME}"
                    }
                </pattern>
            </message>
        </format>
    </appender>

    <!-- Console Appender com mesmo formato JSON -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                {
                "timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}",
                "level":"%level",
                "logger":"%logger{36}",
                "thread":"%thread",
                "message":"%message",
                "requestId":"%X{X-Request-ID}",
                "app":"${name}",
                "pod":"${podName}",
                "namespace":"${podNamespace}",
                "host":"${HOSTNAME}"
                }
            </pattern>
        </encoder>
    </appender>

    <!-- Root Logger -->
    <root level="INFO">
        <appender-ref ref="LOKI"/>
        <appender-ref ref="JSON_CONSOLE"/>
    </root>

</configuration>
